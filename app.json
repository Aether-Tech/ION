{
  "expo": {
    "name": "ION",
    "slug": "ion-app",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/IONlogoNova.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aether.ion"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/IONlogoNova.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.aether.ion.app",
      "versionCode": 16,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "favicon": "./assets/IONlogoNova.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Precisamos de acesso à galeria de fotos para selecionar imagens e enviá-las na conversa.",
          "cameraPermission": "Precisamos de acesso à câmera para tirar fotos e enviá-las na conversa."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Precisamos de acesso ao microfone para gravar mensagens de áudio."
        }
      ],
      "react-native-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "gradleChildHeapSize": "4g",
            "packagingOptions": {
              "pickFirst": [
                "lib/**/libreact_native_all.so",
                "lib/**/libfbjni.so"
              ]
            }
          }
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "scheme": "ion",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8bc85d34-162b-4b6f-bcca-88642b5de117"
      }
    }
  }
}